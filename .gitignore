# Secrets — never commit
.env
.env.*
!.env.example

# Large source scans (live in iCloud / Supabase Storage, not the repo)
/originals/

# PRIVATE: transcriptions hold private family mentions + sensitivity — keep out of the
# public repo. They live locally and go into Supabase (RLS-protected) instead.
/data/transcriptions/
/data/poem-variants.json
# PRIVATE: real family names (fed to the OCR prompt) must never hit the public repo.
/data/family-names.local.json
/data/analysis-errors.json

# Generated / derived
/derivatives/
/verification/
node_modules/
.venv/
.DS_Store

# Next.js / build
/.next/
/out/

# derived scan images for the web app
/web/public/scans/

# web build artifacts
web/.next/
web/out/
web/next-env.d.ts
web/*.tsbuildinfo

# python cache
__pycache__/
*.pyc

# personal Claude Code settings
.claude/settings.local.json
/data/analysis-progress.json
/data/people.json
/data/people-identities.json

# Local deploy runbook (contains infra endpoints; repo is public)
DEPLOY_RUNBOOK.md

# transcription pipeline runtime artifacts (logs + batch metadata; not code)
data/*.log
data/analysis-*.json
data/run-*.log
data/scan-rotations.json
