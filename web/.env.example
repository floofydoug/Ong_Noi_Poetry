# Copy to web/.env (gitignored) for local dev, and fill real values.
# PROD values are set in Amplify's environment (DB creds come from Secrets Manager).

# ---- Database (Aurora Serverless v2, Postgres) ----
# Dev: point at a dev database (e.g. ongnoi_dev) so it never touches prod data.
# Prod (Amplify): injected from Secrets Manager secret `ongnoi/db/master` (or IAM DB auth).
DATABASE_URL="postgresql://USER:PASSWORD@<cluster-endpoint>.us-west-1.rds.amazonaws.com:5432/ongnoi_dev?sslmode=require"

# ---- AWS / storage ----
AWS_REGION="us-west-1"
S3_BUCKET="<scans-bucket>"

# Image serving: DEV leaves this empty → images load from /public/scans (local files).
# PROD sets it to the CloudFront URL fronting the S3 bucket, e.g. https://dxxxx.cloudfront.net
NEXT_PUBLIC_IMAGE_BASE=""

# ---- Auth (Cognito — added in the auth slice) ----
# COGNITO_USER_POOL_ID=""
# COGNITO_CLIENT_ID=""
# COGNITO_REGION="us-west-1"
